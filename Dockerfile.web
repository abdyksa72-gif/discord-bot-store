FROM node:20-alpine AS builder

RUN npm install -g pnpm@9

WORKDIR /app

COPY pnpm-workspace.yaml ./
COPY package.json ./
COPY tsconfig.base.json ./
COPY tsconfig.json ./

COPY lib/ ./lib/
COPY artifacts/discord-bot-store/ ./artifacts/discord-bot-store/

RUN pnpm install --frozen-lockfile

ENV BASE_PATH=/
ENV NODE_ENV=production

RUN pnpm --filter @workspace/discord-bot-store run build

FROM nginx:alpine

COPY --from=builder /app/artifacts/discord-bot-store/dist/public /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
